# ── База данных (обязательно) ────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/explorit
DATABASE_URL_SYNC=postgresql://user:password@localhost:5432/explorit

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT (обязательно) ────────────────────────────────────────────────────────
# Сгенерировать: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Яндекс (опционально) ─────────────────────────────────────────────────────
YANDEX_MAPS_API_KEY=
YANDEX_GEOCODER_API_KEY=
YANDEX_AFISHA_API_KEY=

# ── Push-уведомления (опционально) ───────────────────────────────────────────
FCM_SERVER_KEY=
APNS_KEY_ID=
APNS_TEAM_ID=

# ── S3 / Selectel (обязательно) ──────────────────────────────────────────────
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT_URL=https://s3.ru-7.storage.selcloud.ru
S3_BUCKET_NAME=explorit-media
S3_REGION=ru-1

# ── Настройки приложения ─────────────────────────────────────────────────────
ENVIRONMENT=development
MAX_ROUTE_POINTS=10
DEFAULT_SEARCH_RADIUS_KM=5
CITY_NAME=Самара
CITY_LAT=53.1959
CITY_LON=50.1002
